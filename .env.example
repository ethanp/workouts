# Copy to .env and fill in real values. The app loads `.env` at startup
# (`dotenv.load()` in main.dart) and only `.env` is bundled as a Flutter
# asset — variants like .env.prod / .env.local are not loaded.
#
# SERVER_HOST_LAN: hostname or IP reachable on the LAN (probed first).
# SERVER_HOST_TAILSCALE: hostname or IP reachable over Tailscale (fallback).
#   These describe a network PATH, not a location. The Tailscale host is
#   whichever box (NUC or a cloud VM) is on your tailnet — point
#   SERVER_HOST_TAILSCALE at its MagicDNS name. A cloud-only box has no LAN, so
#   set SERVER_HOST_LAN to the same name or leave it to fail fast.
SERVER_HOST_LAN=<lan-host-or-ip>
SERVER_HOST_TAILSCALE=<tailscale-host-or-magicdns-name>

# Raw HMAC secret the app signs PowerSync JWTs with. The backend's
# WORKOUTS_POWERSYNC_JWT_KEY must equal base64(POWERSYNC_JWT_SECRET).
POWERSYNC_JWT_SECRET=<jwt-secret>

LLM_APP_NAME=workouts
# Must match the backend's LLM_WORKOUTS_SECRET.
LLM_APP_SECRET=<secret-from-infra/.env>
