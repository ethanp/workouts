# Production
# Copy to .env.prod and fill in real values; both keys are required.
#
# SERVER_HOST_LAN: hostname or IP reachable on the LAN (probed first).
# SERVER_HOST_TAILSCALE: hostname or IP reachable over Tailscale (fallback).
SERVER_HOST_LAN=<lan-host-or-ip>
SERVER_HOST_TAILSCALE=<tailscale-host-or-ip>

POWERSYNC_JWT_SECRET=your-jwt-secret

LLM_APP_NAME=workouts
LLM_APP_SECRET=<secret-from-infra/.env.prod>
